# ─── Momo Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# See docs/environment-variables.md for a full reference.
#
#   cp .env.example .env.local

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string for Drizzle ORM.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://momo:password@localhost:5432/momo

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Secret used to sign and encrypt Auth.js JWTs and session cookies.
# REQUIRED. Minimum 32 characters.
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Base URL used by Auth.js to construct OAuth callback URLs.
# Must exactly match the Homepage URL / Authorized redirect URI configured in
# each OAuth provider app.
# In production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Required when the app runs behind a reverse proxy (nginx, Caddy, Traefik, etc.)
# or any ingress controller (Kubernetes, Docker Compose with Traefik, etc.).
# Auth.js v5 checks the Host header and rejects requests from untrusted hosts
# unless this is set to true.
# Set to "true" for all Docker Compose and Kubernetes production deployments.
# Leave as "false" for local development without a reverse proxy.
AUTH_TRUST_HOST=false

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Create an application at https://discord.com/developers/applications
# Add redirect URI: <NEXTAUTH_URL>/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Generic OIDC (optional) ─────────────────────────────────────────────────
# Enable this for self-hosted SSO (Authentik, Keycloak, Zitadel, etc.)
# Leave blank to disable OIDC login.
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=

# ─── Web Push / VAPID ────────────────────────────────────────────────────────
# Required only if you want browser push notifications.
# Generate key pair with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix exposes the public key to the browser (required for push subscriptions)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:admin@example.com

# ─── Cron Job Protection ─────────────────────────────────────────────────────
# Shared secret used to protect cron API routes (/api/cron/*).
# Include in the Authorization header as a Bearer token:
#   Authorization: Bearer <CRON_SECRET>
# If unset, cron routes are unprotected (not recommended in production).
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── Application ──────────────────────────────────────────────────────────────
# Public URL of the application (exposed to the browser, used in PWA + push notifications).
# In production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Must be set to "production" in production deployments.
# Enables stricter CSP headers and disables the PWA service worker in dev.
# development | production | test
NODE_ENV=development

# ─── Legal Pages (DSGVO / § 5 TMG) ──────────────────────────────────────────
# Required for publicly accessible deployments in Germany (and recommended elsewhere).
# These values appear on /impressum and /datenschutz.
# Self-hosted operators must fill these in with their own details.
# See docs/gdpr.md for details.
NEXT_PUBLIC_IMPRINT_NAME=
NEXT_PUBLIC_IMPRINT_ADDRESS=
NEXT_PUBLIC_IMPRINT_EMAIL=
NEXT_PUBLIC_IMPRINT_PHONE=

# ─── Admin Access ─────────────────────────────────────────────────────────────
# Comma-separated list of user UUIDs that have access to the /admin page.
# If unset or empty, the admin page is inaccessible to everyone.
# Example: ADMIN_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
ADMIN_USER_IDS=

# ─── Docker Compose (optional override) ──────────────────────────────────────
# PostgreSQL password used by docker-compose.yml for the db service.
# Must match the password in DATABASE_URL.
POSTGRES_PASSWORD=password
