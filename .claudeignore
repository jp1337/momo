# Dependencies — never edit manually
node_modules/

# Build artifacts
.next/
dist/
build/

# Lock files — auto-managed
package-lock.json

# Git internals
.git/

# OS artifacts
.DS_Store
*.log
*.tmp

# Test coverage
coverage/
.coverage

# Environment files with real secrets
.env
.env.local
.env.*.local

# Drizzle migration snapshots — auto-generated, use _journal.json to understand history
drizzle/meta/

# CI/CD agent reports — historical, not relevant to coding tasks
.claude/reports/

# Documentation site (docs-site/) is INTENTIONALLY NOT ignored.
# Per project rule (memory feedback_user_docs): every user-facing change
# must update docs-site/ alongside docs/. Hiding it from Claude would
# silently break that rule. Only Jekyll build/cache artifacts are excluded:
docs-site/Gemfile.lock
docs-site/_site/
docs-site/.jekyll-cache/

# Large project plan (reference only, not needed for most tasks)
MOMO_PROJEKT_PLAN.md

# Default Next.js public assets — not project assets
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg

# next-intl type declaration — auto-generated, do not edit
types/next-intl.d.ts

# Worker — single-file service worker, only relevant for PWA/push changes
worker/

# Tool/skills runtime directory — not part of the app
.sixth/

# PWA assets — generated by next-pwa at build time, never edit
public/sw.js
public/workbox-*.js
public/swe-worker-*.js

# Alexa Skill — separate Lambda project in alexa-skill/, rarely relevant to app changes
alexa-skill/dist/
alexa-skill/node_modules/
alexa-skill/package-lock.json

# PNG icons — binary assets, not relevant to code tasks
public/*.png

# Drizzle migration SQL files — read only when debugging migration issues
# The schema source of truth is lib/db/schema.ts, not the SQL files
drizzle/*.sql

# TypeScript build info — binary cache, ~350KB, never relevant
tsconfig.tsbuildinfo

# Auto-generated Next.js type declarations
next-env.d.ts

# Config files — rarely changed, standard boilerplate
postcss.config.mjs
eslint.config.mjs

# CHANGELOG — large (30KB+), only relevant when writing release notes
# Read it explicitly when needed rather than loading it into every session
CHANGELOG.md

# LICENSE — standard MIT, never needs editing
LICENSE

# Full OpenAPI 3.1.0 spec object — ~83KB, mostly route schemas.
# Read explicitly when changing API endpoints. Purpose is documented in lib/CLAUDE.md.
lib/openapi.ts
