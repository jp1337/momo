# Dependencies — never edit manually
node_modules/

# Build artifacts
.next/
dist/
build/

# Lock files — auto-managed
package-lock.json

# Git internals
.git/

# OS artifacts
.DS_Store
*.log
*.tmp

# Test coverage
coverage/
.coverage

# Environment files with real secrets
.env
.env.local
.env.*.local

# Drizzle migration snapshots — auto-generated, use _journal.json to understand history
drizzle/meta/

# CI/CD agent reports — historical, not relevant to coding tasks
.claude/reports/

# Documentation site — Jekyll-based static site, not the app itself
docs-site/

# Large project plan (reference only, not needed for most tasks)
MOMO_PROJEKT_PLAN.md

# Default Next.js public assets — not project assets
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg

# next-intl type declaration — auto-generated, do not edit
types/next-intl.d.ts

# Worker — single-file service worker, only relevant for PWA/push changes
worker/

# PWA assets — generated by next-pwa at build time, never edit
public/sw.js
public/workbox-*.js
public/swe-worker-*.js
