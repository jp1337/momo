# Tolerate stale peer-dependency constraints in transitive dependencies.
#
# swagger-ui-react@5.32.1 (which itself supports React 19 via react: ">=16.8.0 <20")
# pins react-debounce-input@=3.3.0 — an abandoned package (last release 2022) whose
# peer constraint caps React at 18. The package is a class-component wrapper around
# <input> that runs fine on React 19; the warning is purely a peer-deps formality.
#
# react-copy-to-clipboard and react-inspector — the other two stale transitive
# deps from swagger-ui-react — are upgraded via npm overrides in package.json.
#
# Removing this line will resurrect the warning. Re-evaluate when:
#  - swagger-ui-react drops react-debounce-input, OR
#  - someone publishes a maintained fork of react-debounce-input.
legacy-peer-deps=true
